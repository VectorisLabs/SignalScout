{
  "name": "@corpwatch/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./contracts": "./src/contracts/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server-entry.ts",
    "start": "tsx src/server-entry.ts",
    "test": "vitest run",
